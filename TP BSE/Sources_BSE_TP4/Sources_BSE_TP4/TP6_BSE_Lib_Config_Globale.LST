  22          void Port_IO_Init()
  23          {
  24   1          // P0.0  -  TX0 (UART0)
  25   1          // P0.1  -  RX0 (UART0)
  26   1          // P0.2  -  INT0 (Tmr0)
  27   1          // P0.3  -  INT1 (Tmr1)
  28   1          // P0.4  -  T2 (Timer2)
  29   1          // P0.5  -  T2EX (Tmr2)
  30   1          // P0.6  -  T4 (Timer4)
  31   1          // P0.7  -  T4EX (Tmr4)
  32   1          // P1.0  -  SYSCLK
  33   1      
  34   1          // P1.2  to P7.7 - Mode GPIO par dķfaut 
  35   1       
  36   1          XBR0      = 0x04; 
  37   1          XBR1      = 0xF4; 
  38   1          XBR2      = 0x58; 
  39   1      
  40   1      // Config pour LED
  41   1          P1MDOUT |= (1<<6);  // P1.6  en Push Pull
  42   1      // Config pour gestion bouton poussoir
  43   1             P3 |= (1<<7); // Mise Ó 1 de P3.7
  44   1             P3MDOUT &= ~(1<<7); // P3.7 en Drain ouvert
  45   1      // Config pour drapeaux matķriels d'interruption  
  46   1      // drapeau INT7 P2.4
  47   1              P2MDOUT |= (1<<4);  // P2.4 en Push Pull
  48   1              P2 &= ~(1<<4);       // P2.4 mis Ó zķro
  49   1      // drapeau INT6 P6.4        
  50   1              P74OUT |= (1<<5);   // P6.4 Ó P6.7 en PP       
  51   1              P6 &= ~(1<<4);       // P6.4 mis Ó zķro
  52   1      // drapeau INT Timer2  P3.5       
  53   1              P3MDOUT |= (1<<5);  // P3.5 en Push Pull
  54   1              P3 &= ~(1<<5);       // 3.5 mis Ó zķro
