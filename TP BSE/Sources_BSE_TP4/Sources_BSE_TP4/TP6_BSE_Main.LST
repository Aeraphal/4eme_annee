  58          //******************************************************************************
  59          void Config_INT7(void)
  60          {
  61   1        P3IF &= ~(1<<7); // IE7 mis ŕ 0 pending flag de INT7 effacé
  62   1        P3IF &= ~(1<<3); // IE7CF mis ŕ 0 - sensibilité int7 front descendant 
  63   1        
  64   1        EIP2 &= ~(1<<5);  // PX7 mis ŕ 0 - INT7 priorité basse
  65   1        EIE2 |= (1<<5);  // EX7 mis ŕ 1 - INT7 autorisée
  66   1      }
  67          //******************************************************************************
  68          void ISR_INT7 (void) interrupt 19
  69          {
  70   1        VISU_INT7 = 1;
  71   1        P3IF &= ~(1<<7); // IE3 mis ŕ 0 - remise ŕ zéro du pending flag de INT7 effacé
  72   1        Event = TO_BE_PROCESSED;
  73   1        VISU_INT7 = 0;
  74   1      } 
  75          
  76          //*****************************************************************************  
  77          //******************************************************************************
  78          void Config_INT6(void)
  79          {
  80   1        P3IF &= ~(1<<7); // IE6 mis ŕ 0 pending flag de INT6 effacé
  81   1        P3IF &= ~(1<<2); // IE6CF mis ŕ 0 - sensibilité int6 front descendant 
  82   1        
  83   1        EIP2 &= ~(1<<4);  // PX6 mis ŕ 0 - INT7 priorité basse
  84   1        EIE2 |= (1<<4);  // EX6 mis ŕ 1 - INT7 autorisée
  85   1      }
  86          
  87          //******************************************************************************
  88          void ISR_INT6 (void) interrupt 18
  89          {
  90   1        SET_VISU_INT6;
  91   1        P3IF &= ~(1<<6); // IE6 mis ŕ 0 - remise ŕ zéro du pending flag de INT6 effacé
  92   1        P3IF ^= (1<<2);   // Action sur IE6CF - Commutation Front montant / Front Descendant
  93   1        Event = TO_BE_PROCESSED;
  94   1        RESET_VISU_INT6;
  95   1      } 
