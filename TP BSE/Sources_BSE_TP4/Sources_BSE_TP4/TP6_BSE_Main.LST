 191          void ISR_Timer4 (void) interrupt 16
 192          {
 193   1        
 194   1        
 195   1        VISU_INT_TIMER4 = 1; 
 196   1        
 197   1        if ((T4CON & (1<<7)) != 0)   // Test TF4 = 1
 198   1        {
 199   2          T4CON &= ~(1<<7);    // RAZ TF4
 200   2          SIG_OUT = !SIG_OUT;   // Génération SIG_OUT
 201   2          // Prise en compte d'un comptage d'évčnements configurable
 202   2          // La lecture de la config 10-100-1000-10000 est faite dans ISR_Timer2
 203   2          RCAP4 = 65536 - Event_to_Count; //Reload compteur d'évčnements
 204   2          // Comptage des overflows (pour compter au delŕ de 65536)   
 205   2          CP_Overflow_Timer4++;
 206   2        }
 207   1        
 208   1        // Sécurité si T4EX est ŕ 1
 209   1        if ((T4CON & (1<<6)) != 0)   // Au cas oů: Test EXF4 = 1
 210   1        { T4CON &= ~(1<<6); } // RAZ EXF4     
 211   1        
 212   1        VISU_INT_TIMER4 = 0;
