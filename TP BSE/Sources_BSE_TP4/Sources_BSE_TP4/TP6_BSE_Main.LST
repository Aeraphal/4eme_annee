 167          void Config_Timer4_Event_Counter(void)
 168          {
 169   1        // Timer 4 configuré en compteur d'évčnements SIG_IN
 170   1        // SIG_IN câblé sur l'entrée T4 du Timer4
 171   1        
 172   1        // Timer4 en mode autorechargement
 173   1        // Mode Counter
 174   1        // CLKTimer = SIG_IN
 175   1        // Valeur rechargement= (65536 - Nbre_Event_to_count)
 176   1        // L'overflow, et donc l'interruption Timer4 signale le comptage de 100 évčnements
 177   1        T4CON = 0x02;   // Flags TF4 et EXF4 effacés
C51 COMPILER V9.60.0.0   TP6_BSE_MAIN                                                      12/20/2022 12:00:22 PAGE 4   

 178   1                        // RCLK1 et TCLK1 ŕ zéro
 179   1                        // Transitions sur T4EX ignorées
 180   1                        // Timer stoppé
 181   1                        // Timer en mode counter
 182   1                        // Mode auto-reload
 183   1        RCAP4 = 65536-Event_to_Count;
 184   1        T4 = RCAP4;
 185   1        T4CON |= (1<<2);      // TR4 = 1 -- Timer2 démarré
 186   1        EIP2 |= (1<<2);      //PT4 = 0 -- Priorité Timer4 haute
 187   1        EIE2 |= (1<<2);      //ET4 = 1 --  INT Timer4 autorisée
 188   1      }
