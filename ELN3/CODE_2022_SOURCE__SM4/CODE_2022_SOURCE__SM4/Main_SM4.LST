0020                 291     Start_pgm:
0020 758100   F      292             mov   sp,#?STACK-1   ; Initialisation de la pile
0023 120000   F      293             call Init_pgm        ; Appel SP de configuration du processeur
0026 7EB7            294                     mov  R6,#0B7H        ; Passage des paramčtres pour l'appel de  Config_Timer
