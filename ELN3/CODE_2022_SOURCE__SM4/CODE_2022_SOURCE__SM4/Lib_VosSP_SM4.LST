                     269     ;******************************************************************************            
                                 
                     270     ; _Read_code
                     271     ;
                     272     ; Description: 
                     273     ;
                     274     ; Paramčtres d'entrée:  R6 (MSB)- R7 (LSB) – Adresse du périphérique d’entrée
                     275     ; Valeur retournée: R7 : contient la valeur du code lu (sur les 6 bits de poids faible). 
                     276     ; Registres modifiés: aucun
                     277     ;******************************************************************************    
                     278     
0000                 279     _Read_code:
0000 C0E0            280                   PUSH ACC
0002 C082            281                               PUSH DPL
0004 C083            282                               PUSH DPH
0006 8F82            283                               MOV DPL, R7
0008 8E83            284                               MOV DPH, R6
000A E0              285                               MOVX A, @DPTR
000B C2E7            286                               CLR ACC.7
000D C2E0            287                               CLR ACC.0
000F 03              288                               RR A
0010 FF              289                               MOV R7, A
0011 D083            290                               POP DPH
0013 D082            291                               POP DPL
0015 D0E0            292                               POP ACC
0017 22              293                   RET
                     294     ;******************************************************************************            
                                            
                     295                               
                     296     ;******************************************************************************            
                                 
                     297     ; _Read_Park_IN
                     298     ;
                     299     ; Description: 
                     300     ;
                     301     ; Paramčtres d'entrée:  R6 (MSB)- R7 (LSB) – Adresse du périphérique d’entrée
                     302     ; Valeur retournée: Bit Carry  0: pas de détection / 1: véhicule détecté 
                     303     ; Registres modifiés: aucun
                     304     ;******************************************************************************    
                     305     
0018                 306     _Read_Park_IN:
0018 C0E0            307                                     PUSH ACC
001A C082            308                                     PUSH DPL
001C C083            309                                     PUSH DPH
001E B80007          310                                     CJNE R0, #00H, Interruption1
0021 8F82            311                                     MOV DPL, R7
0023 8E83            312                                     MOV DPH, R6
0025 E0              313                                     MOVX A, @DPTR
0026 A2E0            314                                     MOV C, ACC.0                            
0028                 315                                     Interruption1:
0028 D083            316                                     POP DPH
002A D082            317                                     POP DPL
002C D0E0            318                                     POP ACC
002E 22              319                                     RET
