0026                 275     Main:          ; Disable the WDT. (IRQs not enabled at this point.)
                     276                    ; If interrupts were enabled, we would need to explicitly disable
                     277                    ; them so that the 2nd move to WDTCN occurs no more than four clock 
                     278                    ; cycles after the first move to WDTCN.
0026 75FFDE          279                    mov   WDTCN, #0DEh
0029 75FFAD          280                    mov   WDTCN, #0ADh
                     281                    ; Enable the Port I/O Crossbar
002C 75E340          282                    mov   XBR2, #40h
                     283                    ; Set P1.6 (LED) as digital output in push-pull mode.  
002F 43BD40          284                    orl   P1MDIN, #40h        
0032 43A540          285                    orl   P1MDOUT,#40h 
