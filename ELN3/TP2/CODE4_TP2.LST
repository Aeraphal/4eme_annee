                     379     ; Paramčtres d'entrée:  R7: valeur de factorielle ŕ calculer
A51 MACRO ASSEMBLER  CODE4_TP2                                                            05/03/2022 12:05:13 PAGE     7

                     380     ;                                               
                     381     ;     
                     382     ; Paramčtres de sortie: R7 Résultat du calcul de factorielle
                     383     ; Registres modifiés:  ?
                     384     ; Pile: ? octets 
                     385     ;******************************************************************************
                     386     
                     387     ;******************************************************************************   
003B                 388     SP_Factorial:
003B C0D0            389            PUSH PSW
003D C0F0            390                PUSH B
003F C0E0            391                PUSH ACC
0041 EF              392                MOV A,R7
0042 1100     F      393                ACALL Fact
0044 FF              394                MOV R7,A
0045 D0E0            395                POP ACC
0047 D0F0            396                POP B
0049 D0D0            397                POP PSW
004B 22              398                RET
                     399     ;FIN SP SP_Factorial   
                     400     ;******************************************************************************
004C 1F              401     Fact:  DEC R7
004D BF0102          402            CJNE R7,#01,Suit_Fact  ;value of R0 is compared with 1
0050 8006            403            SJMP End_Fact          ;if R0=1, Fin SP Fact
0052                 404     Suit_Fact:
0052 8FF0            405                MOV B,R7
0054 A4              406            MUL AB
0055 1100     F      407            ACALL FACT ;calling back the same function
0057 00              408                NOP
0058                 409     End_Fact:
0058 22              410            RET
                     411     ;FIN SP Fact
                     412     ;******************************************************************************    
                     413     END
